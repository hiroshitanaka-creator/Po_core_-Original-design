{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hiroshitanaka-creator/Po_core_-Original-design/blob/main/schemas/reconstruction_plan_v1.schema.json",
  "title": "Po_core reconstruction_plan v1",
  "description": "PR-006 design + runtime contract. Represents an explicit, traceable plan produced by Po_self (Layer 2) after a reconstruct decision. A reconstruction_plan PLANS reconstruction — it does NOT rewrite content. content_rewrite_allowed is const false: execution belongs to a future controlled reconstruction executor. 'jump'/'reject'/'reactivate' source decision types and their plan_types are reserved for future controlled modes and are not behaviorally produced yet. See docs/contracts/RECONSTRUCTION_PLAN_V1.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "request_id",
    "decision_id",
    "source_decision_type",
    "plan_type",
    "plan_status",
    "content_rewrite_allowed",
    "target_step_ids",
    "planning_reason",
    "pressure_summary",
    "planned_operations",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "reconstruction_plan_v1" },
    "plan_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "description": "The po_self_decision that caused this plan."
    },
    "source_decision_type": {
      "type": "string",
      "enum": ["reconstruct", "jump", "reject", "reactivate"],
      "description": "PR-006 behavior uses only 'reconstruct'; the others are reserved for future controlled modes."
    },
    "plan_type": {
      "type": "string",
      "enum": [
        "revise_steps",
        "regenerate_path",
        "suppress_output",
        "reactivate_trace",
        "jump_path"
      ],
      "description": "PR-006 behavior uses only 'revise_steps'. Future mapping: reconstruct->revise_steps, jump->jump_path, reject->suppress_output, reactivate->reactivate_trace."
    },
    "plan_status": {
      "type": "string",
      "enum": ["planned", "blocked", "not_applicable"]
    },
    "content_rewrite_allowed": {
      "const": false,
      "description": "PR-006 plans reconstruction but never rewrites content."
    },
    "target_step_ids": {
      "type": "array",
      "minItems": 0,
      "items": { "type": "string", "minLength": 1 }
    },
    "planning_reason": { "type": "string", "minLength": 1 },
    "pressure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_priority_score",
        "mean_priority_score",
        "critical_count",
        "viewer_feedback_count",
        "max_viewer_pressure",
        "trigger_type"
      ],
      "properties": {
        "max_priority_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "mean_priority_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "critical_count": { "type": "integer", "minimum": 0 },
        "viewer_feedback_count": { "type": "integer", "minimum": 0 },
        "max_viewer_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "trigger_type": { "type": "string", "minLength": 1 }
      }
    },
    "planned_operations": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operation_id",
          "operation_type",
          "target_step_id",
          "rationale",
          "constraints"
        ],
        "properties": {
          "operation_id": { "type": "string", "minLength": 1 },
          "operation_type": {
            "type": "string",
            "enum": [
              "inspect_step",
              "revise_step",
              "preserve_context",
              "request_human_review"
            ]
          },
          "target_step_id": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "constraints": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rewrite_allowed",
              "preserve_trace",
              "requires_future_executor"
            ],
            "properties": {
              "rewrite_allowed": { "const": false },
              "preserve_trace": { "const": true },
              "requires_future_executor": { "const": true }
            }
          }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "trace_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "viewer_feedback_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
