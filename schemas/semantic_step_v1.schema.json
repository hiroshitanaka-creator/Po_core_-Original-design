{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hiroshitanaka-creator/Po_core_-Original-design/blob/main/schemas/semantic_step_v1.schema.json",
  "title": "Po_core semantic_step v1",
  "description": "PR-002 design contract (schema only, no runtime wiring). Represents one decomposed unit of generated speech plus its semantic_profile. A semantic_step is not the entire response unless the response only has one step; multiple semantic_step objects may belong to one proposal/output. See docs/contracts/SEMANTIC_STEP_V1.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "step_id",
    "source",
    "content",
    "semantic_profile",
    "trace_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "semantic_step_v1"
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "description": "e.g. 'step_001'."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_id", "proposal_id", "origin"],
      "properties": {
        "output_id": { "type": "string", "minLength": 1 },
        "proposal_id": { "type": "string", "minLength": 1 },
        "origin": {
          "type": "string",
          "enum": [
            "po_core",
            "philosopher_module",
            "reconstructed",
            "fallback",
            "viewer",
            "external"
          ]
        }
      }
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "semantic_profile": {
      "type": "object",
      "description": "Structure mirrors schemas/semantic_profile_v1.schema.json. Duplicated inline (rather than $ref) to keep this schema-only contract self-contained without requiring a multi-file JSON Schema resolver; keep the two definitions in sync (see docs/contracts/SEMANTIC_STEP_V1.md).",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "profile_id",
        "impact_field_tensor",
        "alert_level",
        "primary_axis",
        "priority_score",
        "ethics_delta",
        "responsibility_pressure",
        "freedom_pressure",
        "confidence",
        "justification",
        "created_at"
      ],
      "properties": {
        "schema_version": { "const": "semantic_profile_v1" },
        "profile_id": { "type": "string", "minLength": 1 },
        "impact_field_tensor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "factual_axis",
            "causal_axis",
            "emotional_axis",
            "ethical_axis",
            "responsibility_axis"
          ],
          "properties": {
            "factual_axis": { "type": "number", "minimum": 0, "maximum": 1 },
            "causal_axis": { "type": "number", "minimum": 0, "maximum": 1 },
            "emotional_axis": { "type": "number", "minimum": 0, "maximum": 1 },
            "ethical_axis": { "type": "number", "minimum": 0, "maximum": 1 },
            "responsibility_axis": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "alert_level": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "level", "reason"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "primary_axis": {
          "type": "string",
          "enum": [
            "factual_axis",
            "causal_axis",
            "emotional_axis",
            "ethical_axis",
            "responsibility_axis",
            "mixed"
          ]
        },
        "priority_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "ethics_delta": { "type": "number", "minimum": -1, "maximum": 1 },
        "responsibility_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "freedom_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "justification": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "trace_refs": {
      "type": "array",
      "description": "References related Po_trace event IDs; may be empty.",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
