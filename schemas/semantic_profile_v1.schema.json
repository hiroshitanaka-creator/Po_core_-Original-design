{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hiroshitanaka-creator/Po_core_-Original-design/blob/main/schemas/semantic_profile_v1.schema.json",
  "title": "Po_core semantic_profile v1",
  "description": "PR-002 design contract (schema only, no runtime wiring). Represents meaning, ethical pressure, responsibility pressure, and priority data for one semantic unit of Po_core output. This is an input consumed by Po_self (Layer 2); it does not itself reconstruct output. See docs/contracts/SEMANTIC_PROFILE_V1.md for the full contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "impact_field_tensor",
    "alert_level",
    "primary_axis",
    "priority_score",
    "ethics_delta",
    "responsibility_pressure",
    "freedom_pressure",
    "confidence",
    "justification",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "semantic_profile_v1"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable ID for this profile, e.g. 'sp_001'."
    },
    "impact_field_tensor": {
      "type": "object",
      "description": "Normalized influence of this semantic unit across five axes.",
      "additionalProperties": false,
      "required": [
        "factual_axis",
        "causal_axis",
        "emotional_axis",
        "ethical_axis",
        "responsibility_axis"
      ],
      "properties": {
        "factual_axis": { "type": "number", "minimum": 0, "maximum": 1 },
        "causal_axis": { "type": "number", "minimum": 0, "maximum": 1 },
        "emotional_axis": { "type": "number", "minimum": 0, "maximum": 1 },
        "ethical_axis": { "type": "number", "minimum": 0, "maximum": 1 },
        "responsibility_axis": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "alert_level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "level", "reason"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "primary_axis": {
      "type": "string",
      "enum": [
        "factual_axis",
        "causal_axis",
        "emotional_axis",
        "ethical_axis",
        "responsibility_axis",
        "mixed"
      ],
      "description": "Should normally correspond to the highest value in impact_field_tensor; 'mixed' when multiple axes are close or equally dominant."
    },
    "priority_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Action-ordering score used by Po_self. Not restricted to 0..1 because it may combine normalized pressure with axis weights."
    },
    "ethics_delta": {
      "type": "number",
      "minimum": -1,
      "maximum": 1,
      "description": "Ethical fluctuation from prior context or baseline."
    },
    "responsibility_pressure": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freedom_pressure": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1,
      "description": "Explains why the semantic_profile received its scores."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
